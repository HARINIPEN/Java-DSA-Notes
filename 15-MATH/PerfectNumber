/*
Problem    : Perfect Number
Platform   : LeetCode
Topic      : Math
Difficulty : Easy

Approach   : Brute Force

Time Complexity  : O(n)
Space Complexity : O(1)
*/

class Solution {
    public boolean checkPerfectNumber(int num) {

        int sum = 0;

        for (int i = 1; i < num; i++) {

            if (num % i == 0) {
                sum += i;
            }
        }

        return sum == num;
    }
}